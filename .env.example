# ============================================
# Backpack API Configuration
# ============================================
BACKPACK_API_KEY=your_api_key_here
BACKPACK_SECRET_KEY=your_secret_key_here
BACKPACK_ENVIRONMENT=devnet

# ============================================
# Trading Configuration
# ============================================
TRADING_SYMBOL=SOL_USDC
INITIAL_CAPITAL=10000.0

# ============================================
# Strategy Parameters
# ============================================
STRATEGY_TRADE_SIZE=0.1
STRATEGY_MIN_INTERVAL=30
STRATEGY_MAX_INTERVAL=120

# ============================================
# Risk Management
# ============================================
# Stop Loss (%)
STOP_LOSS_PERCENT=2.0
# Take Profit (%)
TAKE_PROFIT_PERCENT=5.0
# Trailing Stop (%)
TRAILING_STOP_PERCENT=1.5
# Max Position Size (% of capital)
MAX_POSITION_SIZE_PERCENT=20.0
# Max Daily Loss (% of capital)
MAX_DAILY_LOSS_PERCENT=10.0

# ============================================
# Backtesting Configuration
# ============================================
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_DATA_PATH=./data/historical

# ============================================
# Optimization Configuration
# ============================================
# Enable auto optimization
AUTO_OPTIMIZATION_ENABLED=true
# Optimization interval (hours)
OPTIMIZATION_INTERVAL=24
# Genetic Algorithm settings
GA_POPULATION_SIZE=20
GA_GENERATIONS=50
GA_MUTATION_RATE=0.2

# ============================================
# Adaptive Trading
# ============================================
# Enable adaptive strategy
ADAPTIVE_STRATEGY_ENABLED=true
# Evaluation period (hours)
EVALUATION_PERIOD=24
# Min win rate to continue (%)
MIN_WIN_RATE=40.0
# Adjustment factor for performance
PERFORMANCE_ADJUSTMENT_FACTOR=0.1

# ============================================
# Logging & Reporting
# ============================================
LOG_LEVEL=INFO
ENABLE_TELEGRAM_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
